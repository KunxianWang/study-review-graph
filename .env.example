# OpenAI-compatible model runtime configuration.
# This project can target a Gemini endpoint exposed through an OpenAI-compatible API.
MODEL_PROVIDER=openai_compatible
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://your-openai-compatible-endpoint/v1
OPENAI_MODEL=your_model_name_here

# Optional observability settings. These are not required for local runs.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=study-review-graph

# Reserved for future retrieval extensions. Not used in v0.1 yet.
TAVILY_API_KEY=
